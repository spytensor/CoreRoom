# Rust
/target/
**/*.rs.bk
*.pdb

# Cargo lock — committed for binary crates
# (do not ignore Cargo.lock)

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Local config — never commit project-specific secrets
.env
.env.local
.envrc

# CoreRoom runtime artifacts in development. This repo IS CoreRoom's
# source; devs dogfooding `cr` here will auto-bootstrap personal
# `.coreroom/` roles/configs/gates that do not belong in published source.
/.coreroom/

# Legacy pre-v0.7 development state; keep ignored for old local checkouts.
/.coderoom/

# Spike sandbox leftovers (tmp dirs are normally cleaned by mktemp;
# this catches anything left behind by interrupted runs)
/spike/sandbox-*/

# Test fixtures created at runtime
/tests/.tmp/

# Python helper artifacts
__pycache__/
*.pyc

# Local Claude Code session settings (per-developer; never commit)
.claude/settings.local.json

# OS noise
Thumbs.db
**/*.pending-snap
